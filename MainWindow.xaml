<Window x:Class="PeekMemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PeekMemo"
        Height="400"
        Width="260"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Background="Transparent">

        <Border
         Background="#FFF8BBD0"
        CornerRadius="20"
        Padding="15"
        MouseLeftButtonDown="Border_MouseLeftButtonDown">

            <StackPanel>
                <TextBlock
        Text="PeekMemo"
        FontSize="22"
        FontWeight="Bold"
        Foreground="#333333"
        Margin="0 0 0 10"
        HorizontalAlignment="Center"/>

                <TextBox
        x:Name="MemoTextBox"
        Height="290"
        FontSize="15"
        TextWrapping="Wrap"
        AcceptsReturn="True"
        VerticalScrollBarVisibility="Auto"
        Background="#FFFFF8E1"
        BorderThickness="0"
        Padding="10"
        TextChanged="MemoTextBox_TextChanged"/>

                <TextBlock
        x:Name="SaveStatusText"
        Text="아직 저장되지 않음"
        FontSize="11"
        Foreground="#777777"
        Margin="0 8 0 0"
        HorizontalAlignment="Right"/>
            </StackPanel>

        </Border>

    </Grid>
</Window>
