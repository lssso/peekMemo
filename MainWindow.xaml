<Window x:Class="PeekMemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PeekMemo"
        Height="520"
        Width="400"
        MinHeight="520"
        MinWidth="300"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

   
    
    <Grid Background="Transparent"
      MouseEnter="Window_MouseEnter"
      MouseLeave="Window_MouseLeave"
      MouseLeftButtonDown="Window_MouseLeftButtonDown">

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftColumn" Width="32"/>
            <ColumnDefinition x:Name="RightColumn" Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid
    Grid.Column="1"
    x:Name="MemoBodyContainer">

            <Border
        x:Name="MemoBodyBorder"
        Grid.Row="0"
        Background="#FFF8BBD0"
        CornerRadius="0 20 20 0"
        Padding="15">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0 0 0 10">
                        <StackPanel
                        Orientation="Horizontal"
                        DockPanel.Dock="Right">

                            <Button
                            x:Name="PinButton"
                            Content="📌"
                            Width="28"
                            Height="28"
                            Margin="0 0 6 0"
                            Click="PinButton_Click"/>

                            <Button
                            Content="⚙"
                            Width="28"
                            Height="28"
                            Click="SettingsButton_Click"/>
                        </StackPanel>

                        <TextBlock
                        Text="PeekMemo"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="#333333"
                        HorizontalAlignment="Center"/>
                    </DockPanel>

                    <TextBox
                x:Name="MemoTextBox"
                Grid.Row="1"
                FontSize="15"
                TextWrapping="Wrap"
                AcceptsReturn="True"
                VerticalScrollBarVisibility="Auto"
                Background="#FFFFF8E1"
                BorderThickness="0"
                Padding="10"
                TextChanged="MemoTextBox_TextChanged"
                PreviewMouseLeftButtonDown="MemoTextBox_PreviewMouseLeftButtonDown"/>

                    <TextBlock
                x:Name="SaveStatusText"
                Grid.Row="2"
                Text="아직 저장되지 않음"
                FontSize="11"
                Foreground="#777777"
                Margin="0 8 0 0"
                HorizontalAlignment="Right"/>

                </Grid>
            </Border>

            <Border
                x:Name="ResizeBar"
                Height="10"
                VerticalAlignment="Bottom"
                Background="Transparent"
                Cursor="SizeNS"
                MouseLeftButtonDown="ResizeBar_MouseLeftButtonDown"
                MouseMove="ResizeBar_MouseMove"
                MouseLeftButtonUp="ResizeBar_MouseLeftButtonUp"/>
        </Grid>

        <StackPanel Grid.Column="0" VerticalAlignment="Center" x:Name="MemoTabsPanel">

            <Border
        x:Name="MemoTabBorder1"
        Width="32"
        Height="120"
        Background="#FFFFD54F"
        CornerRadius="20 0 0 20"
        Margin="0 0 0 8"
        MouseLeftButtonDown="MemoTab1_MouseLeftButtonDown">

                <TextBlock
            x:Name="MemoTabText1"
            Text="업무"
            FontSize="14"
            FontWeight="Bold"
            Foreground="#333333"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            RenderTransformOrigin="0.5,0.5">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="90"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Border>

            <Border
        x:Name="MemoTabBorder2"
        Width="32"
        Height="120"
        Background="#FFF8BBD0"
        CornerRadius="20 0 0 20"
        MouseLeftButtonDown="MemoTab2_MouseLeftButtonDown">

                <TextBlock
            x:Name="MemoTabText2"
            Text="개인"
            FontSize="14"
            FontWeight="Bold"
            Foreground="#333333"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            RenderTransformOrigin="0.5,0.5">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="90"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Border>

            <Border
            x:Name="MemoTabBorder3"
            Width="32"
            Height="120"
            Background="#FFBBDEFB"
            CornerRadius="18 0 0 18"
            Margin="0 8 0 0"
            MouseLeftButtonDown="MemoTab3_MouseLeftButtonDown">

                        <TextBlock
                x:Name="MemoTabText3"
                Text="공부"
                FontSize="14"
                FontWeight="Bold"
                Foreground="#333333"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="90"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </Border>

        </StackPanel>

    </Grid>
</Window>
